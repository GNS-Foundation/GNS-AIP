{
  "name": "vercel-gns-aip",
  "version": "0.1.0",
  "description": "GNS-AIP identity, compliance, and delegation for Vercel AI SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vercel", "ai-sdk", "gns", "aip", "agent-identity",
    "compliance", "middleware", "proof-of-trajectory", "eu-ai-act",
    "language-model", "guardrails", "next-js"
  ],
  "author": "GNS Foundation <dev@gnsfoundation.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GNS-Foundation/GNS-AIP",
    "directory": "packages/vercel-gns-aip"
  },
  "peerDependencies": {
    "ai": ">=4.0.0",
    "zod": ">=3.22.0"
  },
  "dependencies": {
    "@gns-aip/sdk": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "zod": "^3.22.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/__tests__"],
    "moduleNameMapper": {
      "^@gns-aip/sdk$": "<rootDir>/__mocks__/@gns-aip/sdk.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
    }
  }
}
